{
    "name": "pl_001_insurance_claims",
    "properties": {
        "description": "Weekly pipeline ingesting claims CSV, running DQ checks, applying PySpark risk scoring, storing Delta Lake output, and loading into Azure SQL DB.",
        "activities": [
            {
                "name": "RunDQCheck",
                "description": "Data quality profiling - nulls, duplicates, schema validation, DQ score",
                "type": "DatabricksNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "notebookPath": "/Users/purusottam.builds@gmail.com/dir_001_claims_insurance/nb_01_dq_check"
                },
                "linkedServiceName": {
                    "referenceName": "ls_databricks",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "RunTransform",
                "description": "PySpark risk scoring, Delta Lake write with schema evolution",
                "type": "DatabricksNotebook",
                "dependsOn": [
                    {
                        "activity": "RunDQCheck",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "notebookPath": "/Users/purusottam.builds@gmail.com/dir_001_claims_insurance/nb_02_transform"
                },
                "linkedServiceName": {
                    "referenceName": "ls_databricks",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "SendSuccessNotification",
                "type": "WebActivity",
                "dependsOn": [
                    {
                        "activity": "LoadToSQL",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "method": "POST",
                    "url": "https://prod-18.southindia.logic.azure.com:443/workflows/bf05dfc8141148b89453b435b57b0b62/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=vJ4MdTz2SoZEg_Y_s4TpQzHDEh2vuplx2oqF86gSJeg",
                    "body": {
                        "value": "{\n  \"status\"   : \"SUCCEED\",\n  \"pipeline\" : \"@{pipeline().Pipeline}\",\n  \"message\"  : \"Insurance Claims pipeline ccompleted successfully — check ADF Monitor for details\",\n  \"runId\"    : \"@{pipeline().RunId}\"\n}",
                        "type": "Expression"
                    }
                }
            },
            {
                "name": "SendFailureAlert",
                "type": "WebActivity",
                "dependsOn": [
                    {
                        "activity": "RunDQCheck",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    },
                    {
                        "activity": "RunTransform",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    },
                    {
                        "activity": "LoadToSQL",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "method": "POST",
                    "url": "https://prod-18.southindia.logic.azure.com:443/workflows/bf05dfc8141148b89453b435b57b0b62/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=vJ4MdTz2SoZEg_Y_s4TpQzHDEh2vuplx2oqF86gSJeg",
                    "body": {
                        "value": "{\n  \"status\"   : \"FAILED\",\n  \"pipeline\" : \"@{pipeline().Pipeline}\",\n  \"message\"  : \"Insurance Claims pipeline FAILED !!! — check ADF Monitor for details\",\n  \"runId\"    : \"@{pipeline().RunId}\"\n}",
                        "type": "Expression"
                    }
                }
            },
            {
                "name": "LoadToSQL",
                "type": "DatabricksNotebook",
                "dependsOn": [
                    {
                        "activity": "RunTransform",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
