{
    "name": "pl_001_insurance_claims",
    "properties": {
        "description": "Weekly pipeline - DQ check, risk scoring, Delta Lake write, SQL load via JDBC, email alerts",
        "activities": [
            {
                "name": "RunDQCheck",
                "type": "DatabricksNotebook",
                "dependsOn": [],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "notebookPath": "/Users/purusottam.builds@gmail.com/dir_001_claims_insurance/nb_01_dq_check"
                },
                "linkedServiceName": {
                    "referenceName": "ls_databricks",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "RunTransform",
                "type": "DatabricksNotebook",
                "dependsOn": [
                    {
                        "activity": "RunDQCheck",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "notebookPath": "/Users/purusottam.builds@gmail.com/dir_001_claims_insurance/nb_02_transform"
                },
                "linkedServiceName": {
                    "referenceName": "ls_databricks",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "LoadToSQL",
                "type": "DatabricksNotebook",
                "dependsOn": [
                    {
                        "activity": "RunTransform",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "notebookPath": "/Users/purusottam.builds@gmail.com/dir_001_claims_insurance/nb_03_load_to_sql"
                },
                "linkedServiceName": {
                    "referenceName": "ls_databricks",
                    "type": "LinkedServiceReference"
                }
            },
            {
                "name": "SendSuccessNotification",
                "type": "WebActivity",
                "dependsOn": [
                    {
                        "activity": "LoadToSQL",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "method": "POST",
                    "url": {
                        "value": "https://prod-01.centralindia.logic.azure.com:443/workflows/ec375a60de8e4ddd997e5dbf32037d01/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=3klC2JC9Fm6ljhnssRQV7LrqhqC95rLhMeFd1YgBDHw",
                        "type": "Expression"
                    },
                    "body": {
                        "value": "{\n  \"status\"   : \"SUCCESS\",\n  \"pipeline\" : \"@{pipeline().Pipeline}\",\n  \"message\"  : \"Insurance Claims pipeline completed successfully\",\n  \"runId\"    : \"@{pipeline().RunId}\"\n}\n",
                        "type": "Expression"
                    }
                }
            },
            {
                "name": "SendFailureAlert",
                "type": "WebActivity",
                "dependsOn": [
                    {
                        "activity": "RunDQCheck",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    },
                    {
                        "activity": "RunTransform",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    },
                    {
                        "activity": "LoadToSQL",
                        "dependencyConditions": [
                            "Failed"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "method": "POST",
                    "url": {
                        "value": "https://prod-01.centralindia.logic.azure.com:443/workflows/ec375a60de8e4ddd997e5dbf32037d01/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=3klC2JC9Fm6ljhnssRQV7LrqhqC95rLhMeFd1YgBDHw",
                        "type": "Expression"
                    },
                    "body": {
                        "value": "{\n  \"status\"   : \"FAILED\",\n  \"pipeline\" : \"@{pipeline().Pipeline}\",\n  \"message\"  : \"Insurance Claims pipeline FAILED — check ADF Monitor for details\",\n  \"runId\"    : \"@{pipeline().RunId}\"\n}\n",
                        "type": "Expression"
                    }
                }
            }
        ],
        "annotations": []
    }
}